# ============================================================
#  .env.example — 複製此檔為 .env 並填入真實值
#  此檔案可安全提交至 Git；.env 絕對不可提交
# ============================================================

# ── Django ───────────────────────────────────────────────────
SECRET_KEY=your-django-secret-key-here
DEBUG=True

# ── Google Gemini AI ─────────────────────────────────────────
GOOGLE_API_KEY=your-google-api-key-here

# ── PostgreSQL ───────────────────────────────────────────────
DB_NAME=resumate_db
DB_USER=postgres
DB_PASSWORD=your-db-password-here

# ── Email (Gmail SMTP) ────────────────────────────────────────
# Gmail 需至「帳號安全性 → 應用程式密碼」產生專用密碼
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your_gmail@gmail.com
EMAIL_HOST_PASSWORD=your_16char_app_password
DEFAULT_FROM_EMAIL=Resumate HR <your_gmail@gmail.com>
